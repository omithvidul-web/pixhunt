<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.PixHunt" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_violet</item>
        <item name="colorPrimaryDark">@color/brand_bg</item>
        <item name="colorAccent">@color/brand_magenta</item>
        <item name="android:statusBarColor">@color/brand_bg</item>
        <item name="android:navigationBarColor">@color/brand_bg</item>
        <item name="android:windowBackground">@color/brand_bg</item>
    </style>

    <style name="Theme.PixHunt.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_bg</item>
        <item name="windowSplashScreenAnimatedIcon" tools:targetApi="s">@mipmap/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.PixHunt</item>
    </style>
</resources>
